# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and must never be committed.
# See docs/environment-variables.md for full details on each variable.

# Supabase project URL (safe to expose to the browser — not a secret)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/publishable key (safe to expose to the browser — currently
# unused by any live code path; see docs/environment-variables.md)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here

# Supabase service-role key — SERVER-ONLY, bypasses Row Level Security.
# Never expose this to the browser. Rotate immediately if ever suspected leaked.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# HTTP Basic Auth credentials for the /admin perimeter (proxy.ts) — SERVER-ONLY
ADMIN_USERNAME=your-admin-username
ADMIN_PASSWORD=your-admin-password

# Configured but not currently read by any code (reserved for future
# analytics/SEO work) — see docs/environment-variables.md
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_SITE_URL=https://your-production-domain.example
